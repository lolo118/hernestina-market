# Get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# New-style publishable key (sb_publishable_*). Either name works; the app
# checks NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY first, then falls back to
# NEXT_PUBLIC_SUPABASE_ANON_KEY for compatibility with older Supabase projects.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret / service-role key — SERVER ONLY. Never expose to the browser.
# Either name works; SUPABASE_SERVICE_ROLE_KEY is checked first.
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY=

# Branding / receipt header
NEXT_PUBLIC_STORE_NAME=Hernestina
